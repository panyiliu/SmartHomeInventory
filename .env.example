SECRET_KEY=change-me-to-a-strong-random-value

# LAN ports exposed by nginx
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443

# App secrets (prefer environment variables over admin UI for production)
# Volcengine (Ark) API key
VOLCENGINE_API_KEY=
FRIDGE_SMTP_PASSWORD=
FRIDGE_BARCODE_APP_SECRET=

# Optional AI log controls
AI_LOG_VERBOSE=0
AI_LOG_FULL_RESPONSE=0

# SQLite backups
BACKUP_RETENTION_DAYS=14

