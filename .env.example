SECRET_KEY=change-me-to-a-strong-random-value

# LAN ports exposed by nginx
NGINX_PORT_HTTP=80
NGINX_PORT_HTTPS=443

# App secrets (prefer environment variables over admin UI for production)
# Volcengine (Ark) API key
VOLCENGINE_API_KEY=
FRIDGE_SMTP_PASSWORD=
FRIDGE_BARCODE_APP_SECRET=

# Optional AI log controls
AI_LOG_VERBOSE=0
AI_LOG_FULL_RESPONSE=0

# SQLite backups
BACKUP_RETENTION_DAYS=14

# B2 S3 single-file backup (CSV)
B2_ENDPOINT=
B2_ACCESS_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_REGION=us-east-1
BACKUP_SOURCE_PATH=/app/instance/items-backup.csv
BACKUP_TARGET_KEY=latest_backup.csv

# Session security
# 登录后会话在“无操作”超过 30 分钟自动失效（防劫持/防长时间挂机）
SESSION_IDLE_TIMEOUT_S=1800
# 兼容 http：默认不强制 Secure Cookie（需要 HTTPS 时再置为 1）
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax

# B2 自动备份调度（UTC）
# 1=启用；0=禁用
BACKUP_ENABLED=0
# Cron 表达式格式：分钟 小时 日 月 星期（共 5 段）
BACKUP_FREQUENCY_CRON=0 3 * * *

